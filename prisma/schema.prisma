generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  vkId      Int       @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  player    Player?
  logs      GameLog[]
}

model Player {
  id               Int                   @id @default(autoincrement())
  userId           Int                   @unique
  name             String?
  level            Int                   @default(1)
  experience       Int                   @default(0)
  gold             Int                   @default(0)
  radiance         Int                   @default(0)
  baseHealth       Int                   @default(4)
  baseAttack       Int                   @default(2)
  baseDefence      Int                   @default(3)
  baseMagicDefence Int                   @default(0)
  baseDexterity    Int                   @default(2)
  baseIntelligence Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress         PlayerProgress?
  inventory        PlayerInventory?
  runes            Rune[]
  battles          BattleSession[]
  rewardLedger     RewardLedgerRecord[]
  commandIntents   CommandIntentRecord[]
  schoolMasteries  PlayerSchoolMastery[]
  skills           PlayerSkill[]
  blueprints       PlayerBlueprint[]
  craftedItems     PlayerCraftedItem[]
  ledParties       PlayerParty[]          @relation("PartyLeader")
  partyMemberships PlayerPartyMember[]
}

model PlayerSchoolMastery {
  playerId    Int
  schoolCode  String
  experience  Int      @default(0)
  rank        Int      @default(0)
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([playerId, schoolCode])
  @@index([schoolCode, rank])
}

model PlayerSkill {
  playerId    Int
  skillCode   String
  experience  Int      @default(0)
  rank        Int      @default(0)
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([playerId, skillCode])
  @@index([skillCode, rank])
}

model PlayerProgress {
  playerId              Int      @id
  locationLevel         Int      @default(0)
  currentRuneIndex      Int      @default(0)
  unlockedRuneSlotCount Int      @default(2)
  activeBattleId        String?
  currentHealth         Int?
  currentMana           Int?
  tutorialState         String   @default("ACTIVE")
  victories             Int      @default(0)
  victoryStreak         Int      @default(0)
  defeats               Int      @default(0)
  defeatStreak          Int      @default(0)
  mobsKilled            Int      @default(0)
  highestLocationLevel  Int      @default(0)
  updatedAt             DateTime @updatedAt
  player                Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model PlayerInventory {
  playerId         Int      @id
  usualShards      Int      @default(0)
  unusualShards    Int      @default(0)
  rareShards       Int      @default(0)
  epicShards       Int      @default(0)
  legendaryShards  Int      @default(0)
  mythicalShards   Int      @default(0)
  leather          Int      @default(0)
  bone             Int      @default(0)
  herb             Int      @default(0)
  essence          Int      @default(0)
  metal            Int      @default(0)
  crystal          Int      @default(0)
  healingPills     Int      @default(0)
  focusPills       Int      @default(0)
  guardPills       Int      @default(0)
  clarityPills     Int      @default(0)
  updatedAt        DateTime @updatedAt
  player           Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model PlayerBlueprint {
  playerId      Int
  blueprintCode String
  quantity      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([playerId, blueprintCode])
  @@index([blueprintCode])
}

model PlayerCraftedItem {
  id            String   @id @default(cuid())
  playerId      Int
  itemCode      String
  itemClass     String
  slot          String
  status        String   @default("ACTIVE")
  equipped      Boolean  @default(false)
  durability    Int
  maxDurability Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, status])
  @@index([playerId, itemCode])
  @@index([playerId, slot, equipped])
}

model Rune {
  id               String   @id @default(cuid())
  playerId         Int
  runeCode         String?  @unique
  archetypeCode    String? 
  passiveAbilityCodes String @default("[]")
  activeAbilityCodes  String @default("[]")
  name             String
  rarity           String
  health           Int      @default(0)
  attack           Int      @default(0)
  defence          Int      @default(0)
  magicDefence     Int      @default(0)
  dexterity        Int      @default(0)
  intelligence     Int      @default(0)
  isEquipped       Boolean  @default(false)
  equippedSlot     Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  player           Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
}

model BattleSession {
  id              String   @id @default(cuid())
  playerId        Int
  status          String   @default("ACTIVE")
  battleType      String   @default("PVE")
  actionRevision  Int      @default(0)
  battleSnapshot  String?
  playerLoadoutSnapshot String? 
  locationLevel   Int
  biomeCode       String
  enemyCode       String
  enemyName       String
  rewardTableCode String? 
  turnOwner       String
  playerSnapshot  String
  enemySnapshot   String
  log             String   @default("[]")
  result          String?
  rewardsSnapshot String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, status])
}

model PlayerParty {
  id             String              @id @default(cuid())
  inviteCode     String              @unique
  leaderPlayerId Int
  status         String              @default("OPEN")
  activeBattleId String?
  maxMembers     Int                 @default(2)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  leader         Player              @relation("PartyLeader", fields: [leaderPlayerId], references: [id], onDelete: Cascade)
  members        PlayerPartyMember[]

  @@index([leaderPlayerId, status])
  @@index([status, activeBattleId])
}

model PlayerPartyMember {
  partyId  String
  playerId Int
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  party    PlayerParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  player   Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([partyId, playerId])
  @@index([playerId])
}

model RewardLedgerRecord {
  id            String   @id @default(cuid())
  playerId      Int
  ledgerKey     String   @unique
  sourceType    String
  sourceId      String
  status        String   @default("APPLIED")
  entrySnapshot String
  appliedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, sourceType, sourceId])
}

model CommandIntentRecord {
  id             String   @id @default(cuid())
  playerId       Int
  intentId       String
  commandKey     String
  stateKey       String
  status         String   @default("PENDING")
  resultSnapshot String   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, intentId])
  @@index([playerId, commandKey])
}

model DeletePlayerReceipt {
  id             String   @id @default(cuid())
  scopeVkId      Int
  intentId       String
  stateKey       String
  status         String   @default("PENDING")
  resultSnapshot String   @default("{}")
  expiresAt      DateTime
  appliedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([scopeVkId, intentId])
  @@index([scopeVkId, status])
}

model GameLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  details   String   @default("{}")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action])
}
