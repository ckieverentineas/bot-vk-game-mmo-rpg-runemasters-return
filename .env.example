# VK Bot Configuration
VK_TOKEN=your_vk_group_token_here
# Optional: if omitted or invalid, the bot will detect the group id automatically from VK_TOKEN
VK_GROUP_ID=

# Database
DATABASE_URL="file:./dev.db"

# Player bootstrap
GAME_STARTING_LEVEL=1
GAME_STARTING_STAT_POINTS=1
GAME_STARTING_USUAL_SHARDS=25
GAME_STARTING_UNUSUAL_SHARDS=10
GAME_STARTING_RARE_SHARDS=3
